# ============================================
# EMAILJS CONFIGURATION FOR PORTO-FAKHUL
# ============================================
#
# INSTRUCTIONS:
# 1. Rename this file to ".env"
# 2. Fill in your EmailJS credentials
# 3. Restart development server
#
# GET YOUR CREDENTIALS FROM:
# - EmailJS Dashboard → Account → API Keys (Public Key)
# - EmailJS Dashboard → Email Services (Service ID)
# - EmailJS Dashboard → Email Templates (Template IDs)
#
# ============================================

# REQUIRED: Your EmailJS Public Key
# Format: user_xxxxxxxxxxxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# REQUIRED: Your EmailJS Service ID  
# Format: service_xxxxxxxx
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# REQUIRED: Notification Template ID
# Template that sends message TO YOU (owner)
# Format: template_xxxxxxxx
VITE_EMAILJS_TEMPLATE_CONTACT=template_notification_id

# OPTIONAL: Auto-Reply Template ID
# Template that sends confirmation TO VISITOR
# Format: template_yyyyyyyy
VITE_EMAILJS_TEMPLATE_AUTOREPLY=template_autoreply_id

# ============================================
# DEVELOPMENT NOTES:
# ============================================
# 1. The app will work WITHOUT EmailJS, but contact form won't send emails
# 2. Check console logs for detailed error messages
# 3. Test with real email addresses (some providers block auto-replies)
# 4. Monitor your EmailJS dashboard for usage statistics
#
# SECURITY NOTE:
# - Public Key is safe to expose in frontend code
# - Add your domain to EmailJS "Allowed Origins" in Security settings
# - Local development: add "http://localhost:5173"
# - Production: add "https://porto-fakhul.vercel.app"
#
# ============================================
# TROUBLESHOOTING:
# ============================================
# Q: Form submits but no email received?
# A: Check Spam folder, verify template IDs, check EmailJS activity log
#
# Q: Getting HTTP 400/403 errors?
# A: Verify domain is in allowed origins, check template variable names
#
# Q: Auto-reply not working?
# A: Make sure VITE_EMAILJS_TEMPLATE_AUTOREPLY is set, template uses {{to_email}}
#
# Q: How to test without real emails?
# A: Use temporary email services or test with your own email first
#
# ============================================
# SUPPORT:
# ============================================
# - EmailJS Docs: https://www.emailjs.com/docs/
# - Portfolio Repo: https://github.com/Lumakara/Porto-Fakhul
# - Contact: fakhulrohman2@gmail.com
#
# ============================================


# ============================================
# AI CHAT BOT CONFIGURATION (Neoxr API)
# ============================================
#
# The floating chat assistant uses the Neoxr API (https://neoxr.eu).
# ALL of these are OPTIONAL — the app has built-in working defaults.
# Override them only if you have your own Neoxr key or want a different model.
#
# Get your own API key from: https://api.neoxr.eu (Dashboard → API Key)
#
# IMPORTANT — valid endpoint paths (verified working):
#   /gpt4    → "Chat GPT-4 Mini"  (recommended primary)
#   /llama   → "Meta Llama 7.1"   (recommended fallback)
#   NOTE: "/gpt4Mini" is NOT a valid path — it returns the Neoxr website HTML.
#
# ============================================

# Base URL of the Neoxr API (no trailing slash)
VITE_NEOXR_BASE_URL=https://api.neoxr.eu/api

# Your Neoxr API key (sent as the `apikey` query parameter)
VITE_NEOXR_API_KEY=oggwWy

# Primary chat endpoint (tried first)
VITE_NEOXR_PRIMARY=/gpt4

# Fallback chat endpoint (used when the primary fails)
VITE_NEOXR_FALLBACK=/llama

# SECURITY NOTE:
# - The Neoxr key is a lightweight client-side usage key.
# - Lock down usage / rate limits in your Neoxr dashboard.
# - For a server-side option that hides the key, the project also ships an
#   /api/chat proxy (api/chat.ts) which reads NEOXR_* (no VITE_ prefix).
