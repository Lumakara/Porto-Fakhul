      "role": "\u7f51\u9875\u5f00\u53d1 | \u7f16\u8f91 | \u8d28\u91cf\u63a7\u5236",
      "bio": "SMK\u4f1a\u8ba1\u4e13\u4e1a\u6bd5\u4e1a\u751f\uff0c\u5728<em>\u6574\u7406\u4e0e\u6280\u672f</em>\u9886\u57df\u6709\u5b9e\u4e60\u7ecf\u9a8c\u3002\u64c5\u957f\u6280\u672f\u3001\u8bbe\u8ba1\u548c\u57fa\u7840\u673a\u5668\u7ef4\u62a4\u3002\u4e60\u60ef\u4e8e\u7ec6\u81f4\u3001\u81ea\u5f8b\u548c\u4ee5\u7ed3\u679c\u4e3a\u5bfc\u5411\u7684\u5de5\u4f5c\u65b9\u5f0f\uff0c\u786e\u4fdd\u4e00\u5207\u7b26\u5408\u516c\u53f8\u6807\u51c6\u3002",
      "bioHighlight": "\u6574\u7406\u4e0e\u6280\u672f",
      "bioText": "SMK\u4f1a\u8ba1\u4e13\u4e1a\u6bd5\u4e1a\u751f\uff0c\u5728\u6574\u7406\u4e0e\u6280\u672f\u9886\u57df\u6709\u5b9e\u4e60\u7ecf\u9a8c\u3002\u64c5\u957f\u6280\u672f\u3001\u8bbe\u8ba1\u548c\u57fa\u7840\u673a\u5668\u7ef4\u62a4\u3002\u4e60\u60ef\u4e8e\u7ec6\u81f4\u3001\u81ea\u5f8b\u548c\u4ee5\u7ed3\u679c\u4e3a\u5bfc\u5411\u7684\u5de5\u4f5c\u65b9\u5f0f\uff0c\u786e\u4fdd\u4e00\u5207\u7b26\u5408\u516c\u53f8\u6807\u51c6\u3002",
      "location": "\u5fb7\u6ce2\uff0c\u897f\u722a\u54c7",
      "experience": "2+\u5e74",
      "trait": "\u9002\u5e94\u6027\u4e0e\u7075\u6d3b\u6027",
