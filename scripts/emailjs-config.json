{
  "emailjs": {
    "publicKey": "VITE_EMAILJS_PUBLIC_KEY",
    "serviceId": "VITE_EMAILJS_SERVICE_ID",
    "templateContact": "VITE_EMAILJS_TEMPLATE_CONTACT",
    "templateAutoReply": "VITE_EMAILJS_TEMPLATE_AUTOREPLY",
    "ownerEmail": "fakhulrohman2@gmail.com",
    "ownerName": "Fakhul Rohman"
  },
  "templates": {
    "notification": {
      "name": "Portfolio Contact Notification",
      "subject": "New Message from {{name}}",
      "to": "fakhulrohman2@gmail.com",
      "variables": ["name", "email", "message", "time", "reply_to"],
      "htmlFile": "public/emailjs-templates/contact-notification.html"
    },
    "autoreply": {
      "name": "Portfolio Auto Reply",
      "subject": "Thank you for reaching out, {{name}}! ✨",
      "to": "{{to_email}}",
      "variables": ["name", "message", "time", "to_email"],
      "htmlFile": "public/emailjs-templates/simple-autoreply.html"
    }
  },
  "security": {
    "allowedOrigins": [
      "http://localhost:5173",
      "https://porto-fakhul.vercel.app"
    ],
    "rateLimit": {
      "freeTier": 200,
      "unit": "emails per month"
    }
  },
  "testing": {
    "testData": {
      "name": "Test User",
      "email": "test@example.com",
      "message": "This is a test message from the portfolio contact form."
    },
    "validEmails": ["fakhulrohman2@gmail.com", "your-test-email@gmail.com"]
  }
}